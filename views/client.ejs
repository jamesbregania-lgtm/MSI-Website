
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=0.8, user-scalable=no" />
    <title>Client Profile — MSI</title>
    <link rel="stylesheet" href="/css/client.css" />
</head>
<body>
    <div class="container">
        <div class="topbar">
            <a href="/user_account" class="btn back-btn">Back to Clients</a>
            <span class="topbar-title" id="page-title">.</span>
            <div style="margin-left:auto; display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
                <span class="topbar-title"><%= currentUser.fullName %></span>
                <a href="/logout" class="btn">Logout</a>
            </div>
        </div>

        <div class="card profile-card">
            <div class="profile-avatar" id="profile-avatar">—</div>
            <div class="profile-info">
                <h1 id="profile-name">—</h1>
                <p id="profile-location">—</p>
            </div>
            <div class="profile-stat">
                <span class="stat-value" id="machine-count">—</span>
                <span class="stat-label">Machines</span>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <div>
                    <h2>Machine Records</h2>
                    <p>All printer assets assigned to this client.</p>
                </div>
                <div class="search-wrap">
                    <svg class="search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input
                        type="text"
                        id="serialSearch"
                        placeholder="Search records..."
                        oninput="filterSerial()"
                    />
                </div>
            </div>

            <div id="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Unit</th>
                            <th>Model</th>
                            <th>Serial No.</th>
                            <th>Date Installed</th>
                            <th>Running Hours</th>
                            <th>Status</th>
                            <th>Maintenance</th>
                        </tr>
                    </thead>
                    <tbody id="machine-tbody">
                        <tr>
                            <td colspan="8" class="loading-row">Loading records...</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="pagination-bar" id="pagination-bar">
                <div class="pagination-controls">
                    <button class="pagination-btn" id="prev-btn" onclick="changePage(-1)" disabled>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                        <span>Prev</span>
                    </button>
                    <div class="pagination-pages" id="pagination-pages"></div>
                    <button class="pagination-btn" id="next-btn" onclick="changePage(1)" disabled>
                        <span>Next</span>
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>
                </div>
            </div>
        </div>

    </div>

    <!-- ── Machine Detail Popup ── -->
    <div class="popup-overlay" id="detailPopup" style="display:none;">
        <div class="popup-card">
            <button class="close-btn" id="closePopup">×</button>
            <h3>Machine Details</h3>
            <dl id="detailList"></dl>
            <div style="margin-top:16px;">
                <button id="viewHistoryBtn" class="history-btn" style="display:none;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    View History
                </button>
            </div>
        </div>
    </div>

    <!-- ── History List Modal ── -->
    <div class="popup-overlay" id="historyPopup" style="display:none;">
        <div class="popup-card" style="width: min(700px, 95vw);">
            <button class="close-btn" id="closeHistoryPopup">×</button>
            <h3>Machine History Records</h3>
            <div class="history-table-wrap">
                <table class="history-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Technician / Submitted By</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="historyList">
                        <tr><td colspan="3" class="loading-row">Loading history...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ── Edit / Update Modal (opened only via warning icon) ── -->
    <div class="popup-overlay" id="editPopup" style="display:none;">
        <div class="popup-card" style="width: min(620px, 96vw); max-height: 90vh; overflow-y: auto;">
            <button class="close-btn" id="closeEditPopup">×</button>
            <h3>Update Machine Record</h3>

            <!-- Read-only display (not editable) -->
            <div class="edit-readonly-section">
                <div class="edit-readonly-row">
                    <span class="edit-readonly-label">Unit</span>
                    <span class="edit-readonly-value" id="edit-unit-display">—</span>
                </div>
                <div class="edit-readonly-row">
                    <span class="edit-readonly-label">Model</span>
                    <span class="edit-readonly-value" id="edit-model-display">—</span>
                </div>
                <div class="edit-readonly-row">
                    <span class="edit-readonly-label">Serial No.</span>
                    <span class="edit-readonly-value" id="edit-serial-display">—</span>
                </div>
            </div>

            <form id="editForm">
                <div class="edit-form-grid">

                    <label class="edit-label" for="edit-runningHours">Running Hours</label>
                    <input class="edit-input" type="number" id="edit-runningHours" min="0" step="1" placeholder="e.g. 14500" required />

                    <label class="edit-label" for="edit-status">Status</label>
                    <select class="edit-input" id="edit-status" required>
                        <option value="">Select status</option>
                        <option value="Active">Active</option>
                        <option value="Maintenance">Maintenance</option>
                        <option value="Faulty">Faulty</option>
                        <option value="Inactive">Inactive</option>
                    </select>

                    <label class="edit-label" for="edit-description">Description</label>
                    <textarea class="edit-input" id="edit-description" rows="3" placeholder="Description"></textarea>

                </div>

                <!-- ── Parts Expiration Checker ───────────────────────── -->
                <div style="margin-top:18px;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#e67e22"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
                        <span style="font-size:13px;font-weight:700;color:var(--navy);">Parts Expiration Checker</span>
                    </div>

                    <!-- Parts table -->
                    <div style="border:1px solid var(--border);border-radius:var(--r-sm);overflow:hidden;">
                        <table style="width:100%;border-collapse:collapse;">
                            <thead>
                                <tr style="background:var(--surface);">
                                    <th style="padding:8px 10px;text-align:left;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid var(--border);">Part</th>
                
                                    <th style="padding:8px 10px;text-align:left;font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid var(--border);">Status / Remaining</th>
                                </tr>
                            </thead>
                            <tbody id="parts-tbody">
                                <tr><td colspan="2" style="text-align:center;color:var(--muted);padding:14px;font-size:13px;">No parts to show.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div style="margin-top:16px; display:flex; gap:10px; justify-content:flex-end;">
                    <button type="button" id="cancelEditBtn" class="btn" style="background:var(--border);color:var(--text);box-shadow:none;">Cancel</button>
                    <button type="submit" class="btn">Save Update</button>
                </div>
            </form>
        </div>
    </div>

    <!-- ── Confirm Modal (custom replacement for browser confirm) ── -->
    <div class="popup-overlay" id="confirmOverlay" style="display:none;">
        <div class="confirm-card" role="dialog" aria-modal="true" aria-labelledby="confirmTitle" aria-describedby="confirmMessage">
            <h3 id="confirmTitle">Please Confirm</h3>
            <p id="confirmMessage">Are you sure?</p>
            <div class="confirm-actions">
                <button type="button" class="btn confirm-btn-cancel" id="confirmCancelBtn">Cancel</button>
                <button type="button" class="btn confirm-btn-ok" id="confirmOkBtn">Confirm</button>
            </div>
        </div>
    </div>

    <script>
        const CLIENT_ID = <%- JSON.stringify(clientId) %>;
        const CLIENTS = <%- JSON.stringify(clients) %>;
        const MACHINE_RECORDS = <%- JSON.stringify(typeof machineRecords !== 'undefined' ? machineRecords : []) %>;
        const CURRENT_USER_FULLNAME = <%- JSON.stringify(currentUser.fullName || '') %>;
    </script>

    <script src="/js/client.js"></script>
</body>
</html>
